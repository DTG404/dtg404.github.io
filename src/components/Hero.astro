---
// Hero — Terminal-style landing intro with typewriter animation
---

<div class="hero">
  <div class="hero-content">
<div class="terminal-bar glass" id="terminal-bar">
        <span class="terminal-dot dot-red"></span>
        <span class="terminal-dot dot-amber"></span>
        <span class="terminal-dot dot-green"></span>
        <span class="terminal-path" id="term-path-text">~/about.sh</span>
      </div>
    <div class="terminal-body glass" id="terminal-body">
      <div id="term-screen"></div>
      <div class="line prompt-end" id="term-cursor-line">
        <span class="nt-prompt">$</span>
        <span class="nt-cursor-blink">_</span>
      </div>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  var screen = document.getElementById('term-screen');
  var cursorLine = document.getElementById('term-cursor-line');
  if (!screen) return;

  var script = [
    { type: 'cmd', text: 'whoami', delay: 400 },
    { type: 'out', text: 'dtg404', cls: 'nt-hl-cyan', delay: 150 },
    { type: 'out', text: ' \u2014 DevOps Lead @ Deloitte', cls: 'nt-hl-magenta', delay: 250 },
    { type: 'cmd', text: 'cat ~/bio.txt', delay: 500 },
    { type: 'out', text: 'Building infrastructure for AI and automation.', cls: 'nt-hl-cyan', delay: 150 },
    { type: 'out', text: 'I make things with code, agents, and creativity.', cls: 'nt-hl-amber', delay: 200 },
    { type: 'out', text: 'Open source. Local-first. Cyberpunk aesthetics.', cls: 'nt-hl-magenta', delay: 200 },
    { type: 'cmd', text: 'ls -la /projects/ | wc -l', delay: 600 },
    { type: 'out', text: '13 public projects across AI agents, infrastructure, dev tools, and creative work', cls: 'nt-hl-green', delay: 300 },
  ];

  var index = 0;

  function typeText(element, text, speed, callback) {
    var i = 0;
    var timer = setInterval(function() {
      if (i < text.length) {
        element.textContent += text[i];
        i++;
      } else {
        clearInterval(timer);
        if (callback) setTimeout(callback, 100);
      }
    }, speed || 20);
    return timer;
  }

  function runScript() {
    cursorLine.style.display = 'none';

    if (index >= script.length) {
      cursorLine.style.display = 'flex';
      return;
    }

    var step = script[index];

    if (step.type === 'cmd') {
      var line = document.createElement('div');
      line.className = 'line';
      line.innerHTML = '<span class="nt-prompt">$</span><span class="nt-cmd"></span>';
      screen.appendChild(line);
      var cmdSpan = line.querySelector('.nt-cmd');

      index++;
      typeText(cmdSpan, step.text, 30 + Math.random() * 20, function() {
        setTimeout(runScript, step.delay || 400);
      });

    } else if (step.type === 'out') {
      var line = document.createElement('div');
      line.className = 'line nt-output' + (step.cls ? ' ' + step.cls : '');
      screen.appendChild(line);

      index++;
      typeText(line, step.text, 12 + Math.random() * 8, function() {
        setTimeout(runScript, step.delay || 150);
      });
    }
  }

  if (document.readyState === 'complete') {
    setTimeout(runScript, 300);
  } else {
    window.addEventListener('load', function() { setTimeout(runScript, 300); });
  }
})();

// ---- GLITCH TEXT EFFECT ----
(function() {
  var pathEl = document.getElementById('term-path-text');
  if (!pathEl) return;
  var original = pathEl.textContent;
  var glitches = [
    '~/about.sh',
    '~/about.sh\x1b[5~',
    '/usr/bin/env',
    'SEGFAULT',
    '~/about.sh 󰀃',
    'nice try',
    '~/about.sh',
  ];

  function doGlitch() {
    // Random interval between 4-12 seconds
    var nextDelay = 4000 + Math.random() * 8000;
    setTimeout(function() {
      // Pick a random glitch text
      var glitchText = glitches[Math.floor(Math.random() * glitches.length)];
      pathEl.textContent = glitchText;
      pathEl.style.color = '#ff00e5';
      pathEl.style.transition = 'color 0.05s';

      // Restore after brief flash
      setTimeout(function() {
        pathEl.textContent = original;
        pathEl.style.color = '';
      }, 120 + Math.random() * 80);

      doGlitch();
    }, nextDelay);
  }

  doGlitch();
})();

// ---- RANDOM HEADING GLITCH ----
(function() {
  var headings = document.querySelectorAll('.card-title, .section-title, .contact-title, .nyx-title');
  if (headings.length === 0) return;

  function randomGlitch() {
    var delay = 6000 + Math.random() * 14000;
    setTimeout(function() {
      var h = headings[Math.floor(Math.random() * headings.length)];
      var orig = h.textContent;
      if (!orig || orig.length < 3) { randomGlitch(); return; }

      // Brief horizontal shift with color split
      h.style.transform = 'translateX(' + (Math.random() > 0.5 ? '2' : '-2') + 'px)';
      h.style.textShadow = '2px 0 #ff00e5, -2px 0 #00f0ff';
      h.style.transition = 'none';

      setTimeout(function() {
        h.style.transform = '';
        h.style.textShadow = '';
        h.style.transition = 'all 0.1s ease-out';
      }, 80 + Math.random() * 60);

      randomGlitch();
    }, delay);
  }

  randomGlitch();
})();
</script>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    padding-top: 5rem;
  }

  .hero-content {
    max-width: 700px;
    width: 100%;
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    border-bottom: none;
    border-radius: 12px 12px 0 0;
  }

  .terminal-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot-red { background: #ff5f57; }
  .dot-amber { background: #ffbd2e; }
  .dot-green { background: #28c840; }

  .terminal-path {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .terminal-body {
    padding: 1.5rem;
    border-radius: 0 0 12px 12px;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    line-height: 1.8;
    min-height: 280px;
  }

  .line {
    margin-bottom: 1px;
    min-height: 1.6em;
  }

  .prompt-end {
    display: flex;
    align-items: center;
    margin-top: 0.3rem;
  }

  /* ---- RUNTIME CLASSES (applied by JS, must be unscoped) ---- */
</style>

<style is:global>
  .nt-prompt {
    color: var(--green);
    margin-right: 0.5rem;
  }

  .nt-cmd {
    color: var(--cyan);
  }

  .nt-output {
    color: var(--text-secondary);
    padding-left: 1.2rem;
    border-left: 2px solid rgba(255, 255, 255, 0.04);
  }

  .nt-hl-cyan {
    color: var(--cyan);
    font-weight: 600;
  }

  .nt-hl-magenta {
    color: var(--magenta);
    font-weight: 500;
  }

  .nt-hl-green {
    color: var(--green);
  }

  .nt-hl-amber {
    color: var(--amber);
  }

  .nt-cursor-blink {
    animation: pulseCursor 0.8s ease-in-out infinite;
    color: var(--cyan);
  }

  @keyframes pulseCursor {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.2; }
  }

  @media (max-width: 640px) {
    .terminal-body {
      font-size: 0.8rem;
      padding: 1rem;
      min-height: 220px;
    }
    .hero {
      padding: 1rem;
      padding-top: 5rem;
    }
  }
</style>