---
// Hero — Terminal-style landing intro
---

<div class="hero">
  <div class="hero-content animate-in stagger-1">
    <div class="terminal-bar glass">
      <span class="terminal-dot dot-red"></span>
      <span class="terminal-dot dot-amber"></span>
      <span class="terminal-dot dot-green"></span>
      <span class="terminal-path">~/about.sh</span>
    </div>
    <div class="terminal-body glass">
      <div class="line">
        <span class="prompt">$</span>
        <span class="cmd">whoami</span>
      </div>
      <div class="line output">
        <span class="highlight-cyan">Xavier Coleman</span>
        <span class="dim"> — </span>
        <span class="highlight-magenta">DevOps Lead @ Deloitte</span>
      </div>
      <div class="line">
        <span class="prompt">$</span>
        <span class="cmd">cat ~/bio.txt</span>
      </div>
      <div class="line output bio">
        Building infrastructure for AI and automation.
        <br />
        I make things with code, agents, and creativity.
        <br />
        Open source. Local-first. Cyberpunk aesthetics.
      </div>
      <div class="line">
        <span class="prompt">$</span>
        <span class="cmd">ls -la /projects/ | wc -l</span>
      </div>
      <div class="line output highlight-green">
        <span class="blink">_</span> 13 public projects across AI agents, infrastructure, dev tools, and creative work
      </div>
      <div class="line prompt-end">
        <span class="prompt">$</span>
        <span class="cursor-blink">_</span>
      </div>
    </div>
  </div>
</div>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    padding-top: 5rem;
  }

  .hero-content {
    max-width: 700px;
    width: 100%;
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    border-bottom: none;
    border-radius: 12px 12px 12px 0 0;
  }

  .terminal-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot-red { background: #ff5f57; }
  .dot-amber { background: #ffbd2e; }
  .dot-green { background: #28c840; }

  .terminal-path {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .terminal-body {
    padding: 1.5rem;
    border-radius: 0 0 12px 12px;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    line-height: 1.8;
  }

  .line {
    margin-bottom: 0.5rem;
  }

  .prompt {
    color: var(--green);
    margin-right: 0.5rem;
  }

  .cmd {
    color: var(--text-primary);
  }

  .output {
    color: var(--text-secondary);
    padding-left: 1.2rem;
    margin-bottom: 0.8rem;
  }

  .bio {
    line-height: 1.6;
  }

  .highlight-cyan {
    color: var(--cyan);
    font-weight: 600;
  }

  .highlight-magenta {
    color: var(--magenta);
    font-weight: 500;
  }

  .highlight-green {
    color: var(--green);
  }

  .dim {
    color: var(--text-muted);
  }

  .blink {
    animation: pulse-glow 1.5s ease-in-out infinite;
    color: var(--green);
  }

  .cursor-blink {
    animation: pulse-glow 1s ease-in-out infinite;
    color: var(--cyan);
  }

  .prompt-end {
    margin-top: 0.3rem;
  }

  @media (max-width: 640px) {
    .terminal-body {
      font-size: 0.8rem;
      padding: 1rem;
    }
    .hero {
      padding: 1rem;
      padding-top: 5rem;
    }
  }
</style>
