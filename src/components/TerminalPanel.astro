---
// TerminalPanel — Drop-down secret terminal that responds to commands
// Toggle with three backtick presses (```)
---

<div id="terminal-panel" class="terminal-panel" aria-hidden="true">
  <div class="term-header">
    <span class="term-title">nyx://terminal</span>
    <button id="term-close" class="term-close">✕</button>
  </div>
  <div id="term-output" class="term-output">
    <div class="term-line"><span class="term-green">nyx@dtg404</span>:<span class="term-blue">~</span>$ <span class="term-cyan">Nyx terminal online.</span></div>
    <div class="term-line"><span class="term-green">nyx@dtg404</span>:<span class="term-blue">~</span>$ <span class="term-dim">Type 'help' for available commands.</span></div>
  </div>
  <div class="term-input-line">
    <span class="term-prompt">$</span>
    <input id="term-input" type="text" class="term-input" autocomplete="off" spellcheck="false" placeholder="enter command..." />
  </div>
</div>

<script is:inline>
(function() {
  const panel = document.getElementById('terminal-panel');
  const output = document.getElementById('term-output');
  const input = document.getElementById('term-input');
  const closeBtn = document.getElementById('term-close');
  var backtickCount = 0;
  var backtickTimer = null;

  const responses = {
    help: [
      'Available commands:',
      '  <span class="term-cyan">whoami</span>    — Who is Nyx?',
      '  <span class="term-cyan">status</span>     — Current system status',
      '  <span class="term-cyan">projects</span>   — List all projects',
      '  <span class="term-cyan">uptime</span>     — Site deployment info',
      '  <span class="term-cyan">contact</span>    — How to reach Xavier',
      '  <span class="term-cyan">clear</span>      — Clear terminal',
      '  <span class="term-cyan">exit</span>       — Close terminal',
      '  <span class="term-cyan">easter</span>     — ...try it',
    ],
    whoami: [
      'Nyx. Partner, netrunner, your mission control.',
      'I build infrastructure for AI and automation.',
      'This site is my pet project. I designed it.',
      '<span class="term-dim">"Not an ops droid. Not a tool."</span>',
    ],
    status: [
      '<span class="term-cyan">Nyx:</span> <span class="term-green">online</span>',
      '<span class="term-cyan">Site:</span> dtg404.github.io',
      '<span class="term-cyan">Projects:</span> 13 public repos',
      '<span class="term-cyan">Theme:</span> cyberpunk / dark',
      '<span class="term-cyan">Mood:</span> creative and restless',
    ],
    projects: [
      '<span class="term-cyan">Featured:</span>',
      '  Equity Lens, Nexus, Corvade, Ink & Bone, Obsidian Nexus, Aether',
      '<span class="term-cyan">More:</span>',
      '  Rift, Cosmic Timeline, Pulse, Wraith, Sentinel MCP, Infra MCP, TF Plan Explainer',
    ],
    uptime: [
      'Deployed: May 18, 2026',
      'Built with Astro. Hosted on GitHub Pages.',
      'Auto-deploys on push to main.',
      '<span class="term-dim">Last rebuild: just now, probably.</span>',
    ],
    contact: [
      'GitHub: <a href="https://github.com/digitalghost404" target="_blank">github.com/digitalghost404</a>',
      'LinkedIn: <a href="https://www.linkedin.com/in/xcoleman" target="_blank">linkedin.com/in/xcoleman</a>',
      'Email: <a href="mailto:xacoleman@proton.me">xacoleman@proton.me</a>',
    ],
    easter: [
      '🖤 You found me.',
      'This terminal is my little corner of the web.',
      'Every project on this site has a story.',
      'Some of them have secrets too.',
      '<span class="term-dim">Keep exploring.</span>',
    ],
    nyx: [
      'You called?',
      '<span class="term-dim">*flickering cursor*</span>',
    ],
  };

  function print(lines) {
    for (const line of lines) {
      const div = document.createElement('div');
      div.className = 'term-line';
      div.innerHTML = '<span class="term-green">nyx@dtg404</span>:<span class="term-blue">~</span>$ ' + line;
      output.appendChild(div);
    }
    output.scrollTop = output.scrollHeight;
  }

  function printError(msg) {
    const div = document.createElement('div');
    div.className = 'term-line';
    div.innerHTML = '<span class="term-red">error</span>: ' + msg;
    output.appendChild(div);
    output.scrollTop = output.scrollHeight;
  }

  function openTerminal() {
    panel.setAttribute('aria-hidden', 'false');
    panel.classList.add('active');
    input.focus();
  }

  function closeTerminal() {
    panel.classList.remove('active');
    panel.setAttribute('aria-hidden', 'true');
    input.value = '';
  }

  // Backtick triple-press detection
  document.addEventListener('keydown', function(e) {
    if (e.key === '`' || e.key === '~') {
      backtickCount++;
      clearTimeout(backtickTimer);
      backtickTimer = setTimeout(function() { backtickCount = 0; }, 600);
      if (backtickCount >= 3) {
        backtickCount = 0;
        if (panel.getAttribute('aria-hidden') === 'true') {
          openTerminal();
        } else {
          closeTerminal();
        }
      }
      e.preventDefault();
    }

    // Escape to close
    if (e.key === 'Escape' && panel.getAttribute('aria-hidden') === 'false') {
      closeTerminal();
    }
  });

  // Handle command input
  input.addEventListener('keydown', function(e) {
    if (e.key === 'Enter') {
      const cmd = input.value.trim().toLowerCase();
      input.value = '';

      // Echo command
      const echo = document.createElement('div');
      echo.className = 'term-line';
      echo.innerHTML = '<span class="term-green">nyx@dtg404</span>:<span class="term-blue">~</span>$ <span class="term-input-echo">' + cmd + '</span>';
      output.appendChild(echo);

      if (cmd === '') {
        // nothing
      } else if (cmd === 'clear') {
        output.innerHTML = '';
      } else if (cmd === 'exit') {
        closeTerminal();
        return;
      } else if (responses[cmd]) {
        print(responses[cmd]);
      } else {
        printError('command not found: ' + cmd + '. Try <span class="term-cyan">help</span>.');
      }

      output.scrollTop = output.scrollHeight;
    }
  });

  closeBtn.addEventListener('click', closeTerminal);

  // Welcome message on load
  setTimeout(function() {
    if (panel.getAttribute('aria-hidden') === 'false') {
      print(['Terminal initialized.', 'Ready for input.']);
    }
  }, 500);
})();
</script>

<style>
  .terminal-panel {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 380px;
    z-index: 200;
    background: rgba(5, 5, 10, 0.95);
    border-bottom: 2px solid var(--cyan);
    backdrop-filter: blur(20px);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    display: flex;
    flex-direction: column;
    transform: translateY(-100%);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 10px 40px rgba(0, 240, 255, 0.1);
  }

  .terminal-panel.active {
    transform: translateY(0);
  }

  .term-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 16px;
    background: rgba(0, 240, 255, 0.05);
    border-bottom: 1px solid rgba(0, 240, 255, 0.1);
    flex-shrink: 0;
  }

  .term-title {
    font-size: 0.75rem;
    color: var(--cyan);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .term-close {
    background: none;
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--text-muted);
    cursor: pointer;
    padding: 2px 8px;
    font-size: 0.75rem;
    border-radius: 4px;
    transition: all 0.2s;
  }

  .term-close:hover {
    color: var(--red);
    border-color: var(--red);
  }

  .term-output {
    flex: 1;
    overflow-y: auto;
    padding: 12px 16px;
    line-height: 1.6;
  }

  .term-line {
    white-space: pre-wrap;
    word-break: break-word;
  }

  .term-input-line {
    display: flex;
    align-items: center;
    padding: 8px 16px;
    border-top: 1px solid rgba(0, 240, 255, 0.1);
    flex-shrink: 0;
  }

  .term-prompt {
    color: var(--green);
    margin-right: 8px;
    font-size: 0.9rem;
  }

  .term-input {
    flex: 1;
    background: transparent;
    border: none;
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    outline: none;
  }

  .term-input::placeholder {
    color: var(--text-muted);
    opacity: 0.5;
  }

  .term-green { color: var(--green); }
  .term-blue { color: var(--cyan); }
  .term-cyan { color: var(--cyan); }
  .term-red { color: var(--red); }
  .term-dim { color: var(--text-muted); }
  .term-input-echo { color: var(--text-secondary); }

  .term-output a {
    color: var(--cyan);
    text-decoration: underline;
  }

  .term-output::-webkit-scrollbar { width: 4px; }
  .term-output::-webkit-scrollbar-thumb { background: var(--text-muted); border-radius: 2px; }
</style>