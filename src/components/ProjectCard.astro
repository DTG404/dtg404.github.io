---
// ProjectCard — Glass project display card
import TechBadge from './TechBadge.astro';

export interface Props {
  slug: string;
  title: string;
  tagline: string;
  description: string;
  tier: string;
  category: string;
  tech: string[];
  links: { github: string; demo: string | null };
}

const { slug, title, tagline, description, tier, category, tech, links } = Astro.props;

const categoryLabels: Record<string, string> = {
  'ai-agents': 'AI / Agents',
  'infrastructure': 'Infrastructure',
  'dev-tools': 'Dev Tools',
  'creative': 'Creative',
  'security': 'Security',
};
---

<a href={`/projects/${slug}`} class="project-card glass glow-cyan animate-in" data-category={category} data-tier={tier} data-repo={links.github.replace('https://github.com/', '')}>
  <div class="card-header">
    <div class="card-meta">
      <span class={`tier-badge ${tier}`}>{tier === 'flagship' ? '★ Flagship' : 'Project'}</span>
      <span class="category-label">{categoryLabels[category] || category}</span>
    </div>
    <h3 class="card-title">{title}</h3>
    <p class="card-tagline">{tagline}</p>
  </div>
  <p class="card-desc">{description}</p>
  <div class="card-tech">
    {tech.slice(0, 6).map(t => <TechBadge tech={t} />)}
    {tech.length > 6 && <span class="tech-more">+{tech.length - 6}</span>}
  </div>
  <div class="card-stats" id={`stats-${slug}`}>
    <span class="card-stat"><span class="stat-icon">&#9733;</span> <span class="stat-val" id={`stars-${slug}`}>--</span></span>
    <span class="card-stat"><span class="stat-icon">&#9679;</span> <span class="stat-val" id={`commits-${slug}`}>--</span></span>
  </div>
  <div class="card-footer">
    <span class="card-link github-link">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
      Source
    </span>
  </div>
</a>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .project-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--cyan), var(--magenta));
    opacity: 0;
    transition: opacity 0.3s;
  }

  .project-card:hover::before {
    opacity: 1;
  }

  .project-card:hover {
    transform: translateY(-4px);
    border-color: rgba(0, 240, 255, 0.2);
    background: rgba(255, 255, 255, 0.05);
  }

  .card-meta {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .tier-badge {
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .tier-badge.flagship {
    background: linear-gradient(135deg, rgba(0, 240, 255, 0.15), rgba(255, 0, 229, 0.15));
    color: var(--cyan);
    border: 1px solid rgba(0, 240, 255, 0.2);
  }

  .tier-badge.project {
    background: rgba(255, 255, 255, 0.05);
    color: var(--text-muted);
    border: 1px solid var(--border-glass);
  }

  .category-label {
    font-size: 0.7rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  .card-title {
    font-size: 1.3rem;
    font-weight: 700;
    background: linear-gradient(135deg, var(--text-primary), var(--cyan));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .card-tagline {
    font-size: 0.85rem;
    color: var(--text-secondary);
    font-style: italic;
    margin-top: 0.2rem;
  }

  .card-desc {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.5;
    -webkit-text-fill-color: var(--text-secondary);
  }

  .card-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tech-more {
    font-size: 0.7rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    padding: 0.2rem 0.4rem;
  }

  .card-footer {
    display: flex;
    justify-content: flex-end;
    margin-top: auto;
  }

  .card-link {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--text-muted);
    transition: color 0.2s;
  }

  .github-link:hover {
    color: var(--cyan);
  }

  .card-stats {
    display: flex;
    gap: 1rem;
    margin-top: auto;
    padding-top: 0.3rem;
  }

  .card-stat {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .stat-icon {
    font-size: 0.6rem;
    opacity: 0.5;
  }

  .stat-val {
    color: var(--text-secondary);
    min-width: 1.5rem;
  }
</style>
