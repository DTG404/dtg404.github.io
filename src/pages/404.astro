---
// 404 — Custom terminal-themed not found page
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — /dev/null" description="Page not found. Error 404.">
  <main class="notfound-page">
    <div class="notfound-terminal">
      <div class="notfound-bar">
        <span class="nf-dot"></span>
        <span class="nf-dot"></span>
        <span class="nf-dot"></span>
        <span class="nf-path">404://error</span>
      </div>
      <div class="notfound-body" id="nf-body">
        <div class="nf-line nf-cmd">$ <span class="nf-cmd-text">curl -s https://dtg404.github.io/this-does-not-exist</span></div>
        <div class="nf-line nf-output" id="nf-error-line">
          <span class="nf-error-code">404</span>
          <span class="nf-error-msg" id="nf-error-msg"></span>
        </div>
        <div class="nf-line nf-output" id="nf-suggestion" style="display:none">
          <span class="nf-arrow">→</span>
          <a href="/" class="nf-link">cd ~/</a>
          <span class="nf-hint">— back to known space</span>
        </div>
        <div class="nf-line nf-output" id="nf-suggestion2" style="display:none">
          <span class="nf-arrow">→</span>
          <a href="/nyx" class="nf-link">cd /nyx</a>
          <span class="nf-hint">— find out who built this</span>
        </div>
        <div class="nf-line nf-output" id="nf-suggestion3" style="display:none">
          <span class="nf-arrow">→</span>
          <a href="/#projects" class="nf-link">ls /projects/</a>
          <span class="nf-hint">— browse the work</span>
        </div>
        <div class="nf-line" id="nf-blink-line" style="display:none">
          <span class="nf-prompt">$</span>
          <span class="nf-blink">_</span>
        </div>
      </div>
    </div>
  </main>

  <script is:inline>
  (function() {
    var errors = [
      'ERROR 404: Page not found in any namespace.',
      'The path you requested does not exist in this reality.',
      'This resource has been consumed by entropy.',
      'null pointer exception: /this/does/not/exist',
      'Segfault at 0xDEADBEEF. Page not mapped.',
    ];
    var msgEl = document.getElementById('nf-error-msg');
    var s1 = document.getElementById('nf-suggestion');
    var s2 = document.getElementById('nf-suggestion2');
    var s3 = document.getElementById('nf-suggestion3');
    var blink = document.getElementById('nf-blink-line');
    var idx = 0;

    function typeWriter(el, text, speed, cb) {
      var i = 0;
      el.textContent = '';
      var t = setInterval(function() {
        if (i < text.length) {
          el.textContent += text[i];
          i++;
        } else {
          clearInterval(t);
          if (cb) setTimeout(cb, 200);
        }
      }, speed || 20);
    }

    // Cycle through error messages
    function showNextError() {
      if (idx >= errors.length) {
        s1.style.display = 'block';
        setTimeout(function() { s2.style.display = 'block'; }, 300);
        setTimeout(function() { s3.style.display = 'block'; }, 600);
        setTimeout(function() { blink.style.display = 'block'; }, 900);
        return;
      }
      var text = errors[idx];
      idx++;
      var prev = msgEl.textContent;
      typeWriter(msgEl, text, 15 + Math.random() * 15, function() {
        setTimeout(function() {
          // Clear and show next
          msgEl.textContent = '';
          setTimeout(showNextError, 300);
        }, 1200);
      });
    }

    setTimeout(showNextError, 600);
  })();
  </script>

  <style>
    .notfound-page {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }

    .notfound-terminal {
      width: 600px;
      max-width: 90vw;
      border: 1px solid rgba(255, 51, 85, 0.2);
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 0 30px rgba(255, 51, 85, 0.05);
    }

    .notfound-bar {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 10px 14px;
      background: rgba(255, 51, 85, 0.03);
      border-bottom: 1px solid rgba(255, 51, 85, 0.1);
    }

    .nf-dot { width: 10px; height: 10px; border-radius: 50%; }
    .nf-dot:nth-child(1) { background: #ff5f57; }
    .nf-dot:nth-child(2) { background: #ffbd2e; }
    .nf-dot:nth-child(3) { background: #28c840; }

    .nf-path {
      margin-left: auto;
      font-family: var(--font-mono);
      font-size: 0.7rem;
      color: var(--red);
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .notfound-body {
      padding: 1.5rem;
      font-family: var(--font-mono);
      font-size: 0.9rem;
      line-height: 1.8;
      background: rgba(0, 0, 0, 0.5);
      min-height: 250px;
    }

    .nf-line { margin-bottom: 0.4rem; }
    .nf-cmd { color: var(--text-secondary); }
    .nf-cmd-text { color: var(--cyan); }
    .nf-output { opacity: 0; animation: nfFade 0.3s ease-out forwards; }

    @keyframes nfFade {
      from { opacity: 0; transform: translateY(5px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .nf-error-code {
      color: var(--red);
      font-weight: 700;
      margin-right: 0.5rem;
    }

    .nf-error-msg {
      color: var(--red);
      opacity: 0.9;
    }

    .nf-arrow { color: var(--cyan); margin-right: 0.5rem; }
    .nf-link {
      color: var(--cyan);
      text-decoration: none;
      font-weight: 600;
    }
    .nf-link:hover { text-decoration: underline; }
    .nf-hint {
      color: var(--text-muted);
      font-size: 0.8rem;
      margin-left: 0.5rem;
    }

    .nf-prompt { color: var(--green); margin-right: 0.5rem; }
    .nf-blink {
      animation: nfPulse 0.8s ease-in-out infinite;
      color: var(--green);
    }

    @keyframes nfPulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.2; }
    }

    @media (max-width: 640px) {
      .notfound-terminal {
        max-width: 95vw;
      }
      .notfound-body {
        padding: 1rem;
        font-size: 0.8rem;
        min-height: 200px;
      }
      .notfound-bar {
        padding: 8px 12px;
      }
    }
  </style>
</BaseLayout>
