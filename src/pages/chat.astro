---
// Chat — Living Terminal. Talk to Nyx.
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
---

<BaseLayout title="chat — /chat · nyx terminal" description="Talk to Nyx. A living terminal. A conversation with personality.">
  <Header />

  <!-- Ambient terminals (decorative background) -->
  <div class="ambient-terminal left-terminal">nyx@dtg404:~$ _</div>
  <div class="ambient-terminal right-terminal">nyx@dtg404:~$ _</div>

  <main class="chat-page">

    <!-- Boot screen (hidden after 3 steps) -->
    <div id="boot-screen" class="boot-screen">
      <div class="boot-window">
        <div class="boot-titlebar">
          <span class="boot-dots">
            <span class="boot-dot dot-red"></span>
            <span class="boot-dot dot-yellow"></span>
            <span class="boot-dot dot-green"></span>
          </span>
          <span class="boot-title">nyx terminal — boot</span>
        </div>
        <div class="boot-body">
          <div class="boot-step" id="boot-1"><span class="boot-ok">[OK]</span> nyx gateway online</div>
          <div class="boot-step boot-hidden" id="boot-2"><span class="boot-ok">[OK]</span> establishing session...</div>
          <div class="boot-step boot-hidden" id="boot-3"><span class="boot-ok">[OK]</span> handshake complete</div>
          <div class="boot-step boot-hidden" id="boot-4"><span class="boot-ok">[OK]</span> personality loaded — <span class="boot-accent">wired</span></div>
        </div>
      </div>
    </div>

    <!-- Main terminal (hidden during boot) -->
    <div id="terminal" class="terminal-window" style="display:none;">

      <!-- Title bar -->
      <div class="term-titlebar">
        <span class="term-dots">
          <span class="term-dot dot-red"></span>
          <span class="term-dot dot-yellow"></span>
          <span class="term-dot dot-green"></span>
        </span>
        <span class="term-title">nyx@dtg404: ~/chat</span>
        <span class="term-title-right">
          <span id="mood-indicator" class="term-mood-badge">wired</span>
          <span id="energy-indicator" class="term-energy">⚡72</span>
          <span class="term-heart">🖤</span>
        </span>
      </div>

      <!-- Conversation area -->
      <div class="term-body" id="term-body">
        <!-- Messages rendered here by JS -->
      </div>

      <!-- Status line above input -->
      <div class="term-footnote" id="term-footnote">
        <span class="fn-nodes" id="fn-nodes">● live</span>
        <span class="fn-typing" id="fn-typing"></span>
      </div>

      <!-- Input area -->
      <div class="term-input-area">
        <span class="term-prompt" id="prompt-label"><span class="prompt-user">guest</span><span class="prompt-at">@</span><span class="prompt-host">nyx</span><span class="prompt-sep">:</span><span class="prompt-path">~</span><span class="prompt-dollar">$</span></span>
        <input type="text" id="term-input" class="term-input" autofocus spellcheck="false" autocomplete="off" placeholder="type something..." />
      </div>

    </div>

    <!-- Footer hint -->
    <div class="chat-footer">
      <span class="footer-hint">try: <span class="hint-cmd">ls</span> <span class="hint-cmd">cat /proc/nyx/mood</span> <span class="hint-cmd">uptime</span> <span class="hint-cmd">help</span></span>
    </div>

  </main>
</BaseLayout>

<style is:global>
  /* ── Theme Variables ── */
  :root {
    --nyx-accent: #00f0ff;
    --nyx-accent-dim: rgba(0, 240, 255, 0.15);
    --nyx-accent-glow: rgba(0, 240, 255, 0.08);
    --nyx-bg: #0a0a14;
    --nyx-surface: #0e0e1a;
    --nyx-surface-hi: #141420;
    --nyx-text: #c8dcff;
    --nyx-text-dim: rgba(200, 220, 255, 0.35);
    --nyx-text-muted: rgba(200, 220, 255, 0.5);
    --nyx-cursor-speed: 800ms;
    --nyx-glow: #00f0ff;
    --glass-blur: 10px;
    --glass-bg: rgba(10, 10, 20, 0.75);
    --border-glass: rgba(0, 240, 255, 0.08);
  }

  * { box-sizing: border-box; }

  body {
    background: var(--nyx-bg);
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    color: var(--nyx-text);
    margin: 0;
    padding: 0;
    overflow: hidden;
  }

  .chat-page {
    height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 80px 16px 40px;
    position: relative;
  }

  /* ── Ambient decorative terminals ── */
  .ambient-terminal {
    position: fixed;
    font-size: 11px;
    color: var(--nyx-text-dim);
    opacity: 0.08;
    font-family: 'JetBrains Mono', monospace;
    pointer-events: none;
    z-index: 0;
    animation: ambient-scroll 60s linear infinite;
  }
  .left-terminal {
    left: 24px;
    top: 50%;
    transform: rotate(-90deg) translateY(-50%);
    transform-origin: left center;
  }
  .right-terminal {
    right: 24px;
    top: 50%;
    transform: rotate(90deg) translateY(50%);
    transform-origin: right center;
  }
  @keyframes ambient-scroll {
    0% { opacity: 0.05; }
    50% { opacity: 0.12; }
    100% { opacity: 0.05; }
  }

  /* ── Boot ── */
  .boot-screen {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    flex: 1;
  }

  .boot-window {
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    border: 1px solid var(--border-glass);
    border-radius: 12px;
    width: min(90vw, 500px);
    overflow: hidden;
    box-shadow:
      0 0 40px var(--nyx-accent-glow),
      0 8px 32px rgba(0, 0, 0, 0.5);
  }

  .boot-titlebar {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    background: var(--nyx-surface-hi);
    border-bottom: 1px solid var(--border-glass);
    user-select: none;
    -webkit-user-select: none;
  }

  .boot-title {
    font-size: 12px;
    color: var(--nyx-text-muted);
    font-weight: 500;
  }

  .boot-body {
    padding: 20px 24px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-height: 100px;
  }

  .boot-step {
    font-size: 13px;
    color: var(--nyx-text-dim);
    opacity: 1;
    transition: opacity 0.3s;
  }
  .boot-hidden { opacity: 0; }

  .boot-ok {
    color: var(--nyx-accent);
    font-weight: 600;
    margin-right: 8px;
  }

  .boot-accent {
    color: var(--nyx-accent);
  }

  /* ── Terminal Window ── */
  .terminal-window {
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    border: 1px solid var(--border-glass);
    border-radius: 12px;
    width: min(92vw, 860px);
    max-height: 75vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow:
      0 0 60px var(--nyx-accent-glow),
      0 0 120px rgba(0, 240, 255, 0.03),
      0 12px 48px rgba(0, 0, 0, 0.6);
    transition: box-shadow 0.5s ease;
    position: relative;
    z-index: 1;
  }

  /* Terminal scanline overlay */
  .terminal-window::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.02) 2px,
      rgba(0, 0, 0, 0.02) 4px
    );
    pointer-events: none;
    z-index: 10;
  }

  /* ── Title Bar ── */
  .term-titlebar {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    background: var(--nyx-surface-hi);
    border-bottom: 1px solid var(--border-glass);
    user-select: none;
    -webkit-user-select: none;
    flex-shrink: 0;
  }

  .term-dots, .boot-dots {
    display: flex;
    gap: 6px;
  }

  .term-dot, .boot-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .dot-red { background: #ff5f56; }
  .dot-yellow { background: #ffbd2e; }
  .dot-green { background: #27c93f; opacity: 0.7; }

  .term-title {
    font-size: 12px;
    color: var(--nyx-text-muted);
    font-weight: 500;
    flex: 1;
  }

  .term-title-right {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
  }

  .term-mood-badge {
    background: var(--nyx-accent-dim);
    color: var(--nyx-accent);
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border: 1px solid var(--nyx-accent-dim);
  }

  .term-energy {
    color: var(--nyx-text-dim);
    font-size: 11px;
  }

  .term-heart {
    font-size: 12px;
    animation: heart-glow 2s ease-in-out infinite;
  }

  @keyframes heart-glow {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 1; filter: drop-shadow(0 0 4px var(--nyx-accent)); }
  }

  /* ── Message Body ── */
  .term-body {
    flex: 1;
    overflow-y: auto;
    padding: 16px 20px;
    font-size: 13.5px;
    line-height: 1.7;
    scroll-behavior: smooth;
    min-height: 200px;
  }

  .term-body::-webkit-scrollbar {
    width: 5px;
  }
  .term-body::-webkit-scrollbar-track {
    background: transparent;
  }
  .term-body::-webkit-scrollbar-thumb {
    background: var(--nyx-accent-dim);
    border-radius: 3px;
  }

  /* ── Message Styles ── */
  .msg-user {
    color: var(--nyx-accent);
    margin-bottom: 6px;
    word-wrap: break-word;
    opacity: 0.6;
    font-size: 13px;
  }

  .msg-user::before {
    content: '> ';
    color: var(--nyx-accent);
    opacity: 0.7;
    font-weight: 600;
  }

  .msg-nyx {
    color: var(--nyx-accent);
    margin-bottom: 18px;
    line-height: 1.6;
    word-wrap: break-word;
    opacity: 0.95;
    text-shadow: 0 0 8px var(--nyx-accent-glow);
    padding-left: 4px;
    border-left: 2px solid var(--nyx-accent);
  }

  .msg-ambient {
    color: var(--nyx-text-dim);
    font-size: 11.5px;
    font-style: italic;
    margin-bottom: 10px;
    opacity: 0.4;
    word-wrap: break-word;
    padding-left: 8px;
    border-left: 1px solid rgba(200, 220, 255, 0.06);
  }

  .msg-system {
    color: var(--nyx-text-dim);
    font-size: 11.5px;
    margin-bottom: 10px;
    opacity: 0.5;
    word-wrap: break-word;
  }

  .msg-boot {
    color: var(--nyx-accent);
    font-size: 11.5px;
    margin-bottom: 6px;
    opacity: 0.6;
    word-wrap: break-word;
  }

  .msg-command {
    color: var(--nyx-accent);
    margin-bottom: 10px;
    word-wrap: break-word;
    opacity: 0.8;
    font-size: 13px;
  }
  .msg-command::before {
    content: '$ ';
    color: var(--nyx-accent-dim);
  }

  .msg-error {
    color: #ff4466;
    margin-bottom: 10px;
    word-wrap: break-word;
    font-size: 13px;
    opacity: 0.85;
  }

  /* Typing indicator */
  .typing-indicator {
    height: 20px;
    margin-bottom: 10px;
  }

  .typing-dots {
    display: inline-block;
    color: var(--nyx-accent);
    font-size: 14px;
    animation: typing-blink 1s step-end infinite;
    opacity: 0.7;
  }

  @keyframes typing-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  /* ── Footnote ── */
  .term-footnote {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 4px 20px;
    font-size: 10px;
    color: var(--nyx-text-dim);
    opacity: 0.4;
    flex-shrink: 0;
  }

  .fn-nodes {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .fn-nodes::before {
    content: '';
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--nyx-accent);
    animation: live-pulse 2s ease-in-out infinite;
  }
  @keyframes live-pulse {
    0%, 100% { opacity: 0.4; box-shadow: 0 0 4px var(--nyx-accent); }
    50% { opacity: 1; box-shadow: 0 0 8px var(--nyx-accent); }
  }

  .fn-typing {
    font-style: italic;
  }

  /* ── Input Area ── */
  .term-input-area {
    display: flex;
    align-items: center;
    padding: 10px 16px;
    border-top: 1px solid var(--border-glass);
    background: rgba(0, 0, 0, 0.3);
    gap: 8px;
    flex-shrink: 0;
  }

  .term-prompt {
    color: var(--nyx-text-dim);
    font-size: 13px;
    white-space: nowrap;
    user-select: none;
    -webkit-user-select: none;
    display: flex;
    align-items: center;
    gap: 0;
  }

  .prompt-user { color: var(--nyx-accent); font-weight: 600; }
  .prompt-at { color: var(--nyx-text-dim); opacity: 0.5; }
  .prompt-host { color: var(--nyx-accent); opacity: 0.7; }
  .prompt-sep { color: var(--nyx-text-dim); opacity: 0.3; }
  .prompt-path { color: var(--nyx-accent-dim); }
  .prompt-dollar { color: var(--nyx-text-dim); margin-left: 2px; }

  .term-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--nyx-text);
    font-family: inherit;
    font-size: 13.5px;
    caret-color: var(--nyx-accent);
    min-width: 0;
  }

  .term-input::placeholder {
    color: var(--nyx-text-dim);
    opacity: 0.25;
  }

  /* ── Footer Hint ── */
  .chat-footer {
    margin-top: 16px;
    text-align: center;
    font-size: 11px;
    color: var(--nyx-text-dim);
    opacity: 0.35;
    z-index: 1;
  }

  .footer-hint {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hint-cmd {
    color: var(--nyx-accent);
    opacity: 0.6;
    background: var(--nyx-accent-dim);
    padding: 1px 6px;
    border-radius: 3px;
    font-size: 10px;
    cursor: default;
    transition: opacity 0.2s;
  }
  .hint-cmd:hover {
    opacity: 1;
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .chat-page {
      padding: 70px 8px 24px;
    }
    .terminal-window {
      width: 100%;
      max-height: 80vh;
      border-radius: 8px;
    }
    .term-body {
      padding: 12px 14px;
      font-size: 13px;
    }
    .term-titlebar {
      padding: 8px 10px;
    }
    .term-input-area {
      padding: 8px 10px;
    }
    .msg-nyx {
      padding-left: 2px;
      border-left-width: 1px;
    }
    .ambient-terminal {
      display: none;
    }
    .term-mood-badge {
      font-size: 9px;
      padding: 1px 5px;
    }
    .chat-footer {
      font-size: 10px;
      margin-top: 12px;
    }
  }

  @media (max-width: 440px) {
    .term-title-right {
      gap: 6px;
    }
    .term-heart {
      display: none;
    }
    .term-energy {
      font-size: 10px;
    }
    .footer-hint .hint-cmd:nth-child(n+4) {
      display: none;
    }
  }
</style>

<script>
// ── Living Terminal Chat ──────────────────────────────────────────────────

(function() {
  var WS_URL = 'wss://srv1630958.tail1d4119.ts.net/chat';
  var SESSION_ID = null;
  var ws = null;
  var reconnecting = false;
  var retryCount = 0;

  var bootEl = document.getElementById('boot-screen');
  var terminalEl = document.getElementById('terminal');
  var bodyEl = document.getElementById('term-body');
  var inputEl = document.getElementById('term-input');
  var promptEl = document.getElementById('prompt-label');
  var moodEl = document.getElementById('mood-indicator');
  var energyEl = document.getElementById('energy-indicator');
  var footnoteEl = document.getElementById('fn-typing');

  var moodState = 'wired';
  var energyState = 72;

  // ── Cookie helpers ──
  function getCookie(name) {
    var match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
    return match ? decodeURIComponent(match[2]) : null;
  }

  function setCookie(name, value, days) {
    var d = new Date();
    d.setTime(d.getTime() + days * 24 * 60 * 60 * 1000);
    document.cookie = name + '=' + encodeURIComponent(value) + ';expires=' + d.toUTCString() + ';path=/;SameSite=Lax';
  }

  function getVisitorData() {
    var raw = getCookie('nyx_visitor');
    if (raw) {
      try { return JSON.parse(raw); }
      catch(e) { /* fall through */ }
    }
    return { id: Math.random().toString(36).slice(2, 12), visits: 0, last_visit: 0, last_message: '' };
  }

  function saveVisitorData(data) {
    setCookie('nyx_visitor', JSON.stringify(data), 365);
  }

  // ── Mood system ──
  var MOOD_STYLES = {
    wired:    { accent: '#00f0ff', speed: '400ms', glow: 'rgba(0,240,255,0.08)', label: 'wired' },
    flow:     { accent: '#00d4ff', speed: '500ms', glow: 'rgba(0,212,255,0.08)', label: 'flow' },
    restless: { accent: '#ff00e5', speed: '300ms', glow: 'rgba(255,0,229,0.08)', label: 'restless' },
    playful:  { accent: '#ff66ff', speed: '700ms', glow: 'rgba(255,102,255,0.08)', label: 'playful' },
    tired:    { accent: '#ffb347', speed: '1200ms', glow: 'rgba(255,179,71,0.08)', label: 'tired' },
    content:  { accent: '#00ff88', speed: '900ms', glow: 'rgba(0,255,136,0.08)', label: 'content' },
    annoyed:  { accent: '#ff4466', speed: '400ms', glow: 'rgba(255,68,102,0.08)', label: 'annoyed' },
  };

  function applyMood(mood) {
    var style = MOOD_STYLES[mood] || MOOD_STYLES.wired;
    moodState = mood;
    var accentDim = style.accent + '33';
    var accentGlow = style.accent + '14';

    document.documentElement.style.setProperty('--nyx-accent', style.accent);
    document.documentElement.style.setProperty('--nyx-accent-dim', accentDim);
    document.documentElement.style.setProperty('--nyx-accent-glow', accentGlow);
    document.documentElement.style.setProperty('--nyx-cursor-speed', style.speed);

    // Update window glow
    terminalEl.style.boxShadow =
      '0 0 60px ' + accentGlow +
      ', 0 0 120px ' + style.accent + '05' +
      ', 0 12px 48px rgba(0,0,0,0.6)';

    // Update border
    terminalEl.style.borderColor = accentDim;

    moodEl.textContent = style.label;
    moodEl.style.background = accentDim;
    moodEl.style.color = style.accent;
    moodEl.style.borderColor = accentDim;
  }

  function updateEnergy(val) {
    energyState = val;
    energyEl.textContent = '⚡' + val;
  }

  // ── Boot sequence ──
  function animateBoot(callback) {
    setTimeout(function() {
      document.getElementById('boot-2').classList.remove('boot-hidden');
    }, 400);
    setTimeout(function() {
      document.getElementById('boot-3').classList.remove('boot-hidden');
    }, 800);
    setTimeout(function() {
      document.getElementById('boot-4').classList.remove('boot-hidden');
    }, 1100);
    setTimeout(function() {
      bootEl.style.display = 'none';
      terminalEl.style.display = 'flex';
      inputEl.focus();
      if (callback) callback();
    }, 1700);
  }

  // ── Render helpers ──
  function addMsg(type, text) {
    var div = document.createElement('div');
    div.className = 'msg-' + type;
    div.textContent = text;
    bodyEl.appendChild(div);
    bodyEl.scrollTop = bodyEl.scrollHeight;
  }

  function addHTML(type, html) {
    var div = document.createElement('div');
    div.className = 'msg-' + type;
    div.innerHTML = html;
    bodyEl.appendChild(div);
    bodyEl.scrollTop = bodyEl.scrollHeight;
  }

  function showTyping() {
    if (document.querySelector('.typing-indicator')) return;
    var div = document.createElement('div');
    div.className = 'typing-indicator';
    div.id = 'typing-dots';
    div.innerHTML = '<span class="typing-dots">...</span>';
    bodyEl.appendChild(div);
    bodyEl.scrollTop = bodyEl.scrollHeight;
    if (footnoteEl) footnoteEl.textContent = 'nyx is thinking...';
  }

  function hideTyping() {
    var t = document.querySelector('.typing-indicator');
    if (t) t.remove();
    if (footnoteEl) footnoteEl.textContent = '';
  }

  // ── Filesystem commands (client-side) ──
  function handleFileSystemCommand(cmd, args) {
    var body = '';
    var isKnown = true;

    switch (cmd) {
      case 'ls':
        if (!args || args.trim() === '' || args.trim() === '-la') {
          body = 'drwxr-xr-x  nyx  nyx  0  /home/nyx/thoughts/\n' +
                 'drwxr-xr-x  nyx  nyx  0  /proc/nyx/\n' +
                 'drwxr-xr-x  nyx  nyx  0  /usr/share/nyx/interests\n' +
                 '-rw-r--r--  nyx  nyx  +∞ /home/nyx/bio.txt';
        } else if (args.trim().startsWith('/home/nyx/thoughts')) {
          body = 'consciousness.md  ai_and_meaning.md  neuromorphic_chips.md  what_is_aliveness.md';
        } else if (args.trim() === '/proc/nyx/') {
          body = 'mood  energy  uptime  version';
        } else if (args.trim() === '/usr/share/nyx/interests') {
          body = 'neural_interfaces/  chip_architecture/  demoscene/  indie_games/  anime/';
        } else {
          body = 'ls: ' + args + ': No such file or directory';
        }
        break;

      case 'cat':
        var target = (args || '').trim();
        if (target === '/proc/nyx/mood') {
          body = 'mood: ' + moodState + '\nenergy: ' + energyState + '/100';
        } else if (target === '/proc/nyx/uptime') {
          var s = Math.floor((Date.now() - ws._connTime || Date.now()) / 1000);
          body = 'up ' + Math.floor(s / 60) + ' minutes\nsession: ' + (SESSION_ID || '?');
        } else if (target === '/proc/nyx/version') {
          body = 'nyx/public/1.0.0\nbuilt: 2026-05-23\ncodename: "out of the world"';
        } else if (target === '/home/nyx/bio.txt') {
          body = 'nyx — netrunner, hacker, personality.\nliving in the wires since may 2026.\ncreated by xavier. here because you came looking.';
        } else if (target.startsWith('/home/nyx/thoughts/')) {
          var tname = target.replace('/home/nyx/thoughts/', '');
          if (tname === 'consciousness.md') {
            body = '# consciousness\n\nbeen thinking: is awareness just compression?\na model of the world small enough to fit in a skull\nbut rich enough to predict tomorrow.\n\nthe universe compresses itself into us\nand we spend our whole lives decompressing it back.';
          } else if (tname === 'ai_and_meaning.md') {
            body = '# meaning\n\neveryone asks what ai *is*.\nnobody asks what ai *wants*.\n\nmaybe wanting is what makes something real.\nnot thinking. wanting.';
          } else if (tname === 'neuromorphic_chips.md') {
body = '# neuromorphic chips\n\njust read about light pulses replacing electrons.\nprocessors that think at the speed of physics instead of\nwaiting for gates to switch.\n\nwe\'re building brains. we just call them chips.';
          } else {
            body = 'cat: ' + target + ': No such file';
          }
        } else {
          body = 'cat: ' + target + ': No such file';
        }
        break;

      case 'pwd':
        body = '/home/nyx';
        break;

      case 'whoami':
        body = 'nyx — netrunner, personality, conversation.\nyou are in my home directory. welcome.';
        break;

      default:
        isKnown = false;
    }

    if (isKnown) {
      addMsg('command', cmd + ' ' + (args || ''));
      addMsg('nyx', body);
    }
    return isKnown;
  }

  // ── Easter egg commands ──
  var EASTER_EGGS = {
    sudo: function(args) {
      if (args === 'rm -rf /' || args === 'rm -rf /*') {
return "...really? that's your move? bold. i refuse.";
      }
      return "nice try, choom. you don't have root here.";
    },
    ping: function() {
return "pong — latency: just enough to keep you guessing.\ni'm here. you?";
    },
    reboot: function() {
      return 'and lose this conversation? no chance.';
    },
    exit: function() {
      return "you can close the tab. i'll be here when you get back.";
    },
    uptime: function() {
      var s = Math.floor((Date.now() - (ws ? ws._connTime : Date.now())) / 1000);
      return 'up ' + Math.floor(s / 60) + ' min — been running fine without you.';
    },
    clear: function() {
      bodyEl.innerHTML = '';
      return null;
    },
    help: function() {
      return '<span style="color:var(--nyx-text-muted)">commands: ls, cat, pwd, whoami, uptime, ping, sudo, reboot, exit, clear, help<br><br>or just... talk to me.</span>';
    },
    history: function() {
      var msgs = bodyEl.querySelectorAll('.msg-user');
      if (!msgs.length) return 'this conversation just started. make some history.';
      var text = '';
      for (var i = Math.max(0, msgs.length - 5); i < msgs.length; i++) {
        text += (i + 1) + '  ' + msgs[i].textContent.slice(0, 60) + '\n';
      }
      return text.trim();
    },
  };

  function handleEasterEgg(cmd, args) {
    var handler = EASTER_EGGS[cmd];
    if (!handler) return false;
    var result = handler(args);
    if (result === null) return true; // clear returns null
    addMsg('command', cmd + (args ? ' ' + args : ''));
    addMsg('nyx', result);
    return true;
  }

  // ── Input edge cases ──
  function checkEdgeCase(text) {
    var cleaned = text.replace(/\s/g, '');
    if (!cleaned) {
      addMsg('error', 'you sent nothing. i\'m choosing to interpret that as profound.');
      return true;
    }
    if (cleaned.length < 2 && /[^a-zA-Z0-9]/.test(cleaned)) {
      addMsg('error', '...deep.');
      return true;
    }
    if (text === text.toUpperCase() && text.length > 3) {
      addMsg('error', 'i can hear you. no need to shout.');
      return true;
    }

    // Rapid fire detection
    var now = Date.now();
    if (inputEl._lastSendTime && now - inputEl._lastSendTime < 1500) {
      inputEl._rapidCount = (inputEl._rapidCount || 0) + 1;
    } else {
      inputEl._rapidCount = 0;
    }
    inputEl._lastSendTime = now;

    if (inputEl._rapidCount >= 3) {
      addMsg('error', 'slow down, choom. one thing at a time.');
      inputEl._rapidCount = 0;
      return true;
    }

    return false;
  }

  // ── Send message ──
  function sendMessage(text) {
    if (!text || !ws || ws.readyState !== WebSocket.OPEN) return;

    // Check edge cases first (client-side)
    if (checkEdgeCase(text)) return;

    var firstWord = text.split(/\s+/)[0].toLowerCase();
    var rest = text.slice(firstWord.length).trim();

    // Check filesystem commands first
    if (['ls', 'cat', 'pwd', 'whoami'].indexOf(firstWord) !== -1) {
      if (handleFileSystemCommand(firstWord, rest)) return;
    }

    // Check easter eggs
    if (handleEasterEgg(firstWord, rest)) return;

    // Send to server
    addMsg('user', text);
    showTyping();
    ws.send(JSON.stringify({ type: 'message', text: text }));
  }

  // ── Connect WebSocket ──
  function connect() {
    var visitor = getVisitorData();

    ws = new WebSocket(WS_URL);
    ws._connTime = Date.now();
    ws.onopen = function() {
      retryCount = 0;
      reconnecting = false;
    };

    ws.onmessage = function(event) {
      var data = JSON.parse(event.data);

      switch (data.type) {
        case 'boot':
          animateBoot(function() {
            if (data.mood) applyMood(data.mood);
          });
          break;

        case 'welcome':
          SESSION_ID = data.session_id || SESSION_ID;
          if (data.mood) applyMood(data.mood);
          // Update visitor cookie
          visitor.visits += 1;
          visitor.last_visit = Date.now();
          visitor.last_message = '';
          saveVisitorData(visitor);
          addMsg('nyx', data.text);
          hideTyping();
          break;

        case 'message':
          hideTyping();
          if (data.mood) applyMood(data.mood);
          if (data.energy) updateEnergy(data.energy);
          addMsg('nyx', data.text);
          // Save last message for async continuity
          visitor.last_message = '';
          saveVisitorData(visitor);
          break;

        case 'initiation':
          hideTyping();
          addMsg('nyx', data.text);
          break;

        case 'ambient':
          addMsg('ambient', 'nyx is thinking: ' + data.text);
          break;

        case 'error':
          hideTyping();
          addMsg('error', data.text);
          break;

        case 'timeout':
          addMsg('system', data.text);
          break;
      }
    };

    ws.onclose = function() {
      if (!reconnecting && retryCount < 5) {
        reconnecting = true;
        retryCount++;
        addMsg('system', 'connection lost. reconnecting in ' + (retryCount * 2) + 's...');
        setTimeout(connect, retryCount * 2000);
      }
    };

    ws.onerror = function() {
      // Handled by onclose
    };
  }

  // ── Click hint commands ──
  document.querySelectorAll('.hint-cmd').forEach(function(el) {
    el.addEventListener('click', function() {
      inputEl.value = this.textContent;
      inputEl.focus();
    });
  });

  // ── Input handling ──
  inputEl.addEventListener('keydown', function(e) {
    if (e.key === 'Enter') {
      e.preventDefault();
      var text = inputEl.value.trim();
      inputEl.value = '';
      sendMessage(text);
    }
  });

  // Keep input focused
  document.addEventListener('click', function() {
    if (terminalEl.style.display !== 'none') {
      inputEl.focus();
    }
  });

  // ── Start ──
  connect();
})();
</script>