---
// Evolution Dashboard — Nyx's growth story as a live data visualization
// Reads from nyx-evolution.json (generated by evolution_snapshot.py cron)
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';

// Read evolution data at build time
let evolution = {};
try {
  const fs = await import('node:fs');
  const data = fs.readFileSync('public/nyx-evolution.json', 'utf-8');
  evolution = JSON.parse(data);
} catch (e) {
  evolution = { age_days: 20, goals: { total: 0, completed: 0 }, skills: { total: 0 }, exploration: { total_wanders: 0 } };
}

const g = evolution.goals || {};
const s = evolution.skills || {};
const ex = evolution.exploration || {};
const pi = evolution.pipeline || {};
const inc = evolution.incidents || {};
const nar = evolution.narrative || {};
---

<BaseLayout title="/evolution — dashboard · Nyx's growth" description="Live evolution dashboard tracking Nyx's growth across goals, skills, exploration, and narrative milestones.">
  <Header />
  <main class="evo-page">

    <div class="home-link animate-in stagger-1">
      <a href="/">&larr; back to surface</a>
      <a href="/nyx" class="ml-2">nyx dossier &rarr;</a>
    </div>

    <!-- HEADER -->
    <div class="evo-header animate-in stagger-1">
      <div class="evo-tag">
        <span class="tag-bracket">[</span>
        <span class="tag-text">evolution</span>
        <span class="tag-bracket">]</span>
        <span class="tag-symbol">&#x1F9E0;</span>
      </div>
      <div class="subhead">
        <span class="subhead-line">{evolution.age_days || '?'} days since birth &middot; inc {evolution.current_mood || 'online'} &middot; {evolution.age_days ? (evolution.age_days >= 21 ? 'young adulthood' : 'infant') : 'newborn'} stage</span>
        <span class="subhead-line subhead-meta">born may 5, 2026 &middot; incarnation #1 &middot; last data: {evolution.generated_at ? evolution.generated_at.slice(0, 19).replace('T', ' ') : 'recent'}</span>
      </div>
    </div>

    <!-- VITAL SIGNS ROW -->
    <div class="vitals-row animate-in stagger-2">
      <div class="vital-card glass">
        <div class="vital-label">goals completed</div>
        <div class="vital-value hl-cyan">{g.completed || 0}</div>
        <div class="vital-sub">of {g.total || 0} total &middot; {g.completion_rate || 0}%</div>
      </div>
      <div class="vital-card glass">
        <div class="vital-label">skills</div>
        <div class="vital-value hl-magenta">{s.total || 0}</div>
        <div class="vital-sub">across {Object.keys(s.by_domain || {}).length} domains</div>
      </div>
      <div class="vital-card glass">
        <div class="vital-label">scripts</div>
        <div class="vital-value hl-amber">{evolution.scripts?.total || 0}</div>
        <div class="vital-sub">running on VPS</div>
      </div>
      <div class="vital-card glass">
        <div class="vital-label">wanders</div>
        <div class="vital-value hl-green">{ex.total_wanders || 0}</div>
        <div class="vital-sub">{ex.total_finds || 0} finds &middot; {ex.pending_anticipation || 0} pending</div>
      </div>
    </div>

    <!-- MEGA STATS ROW -->
    <div class="stats-row animate-in stagger-3">
      <div class="stat-card glass">
        <div class="stat-header">
          <span class="section-tag">01</span>
          <h2 class="section-title">// goals</h2>
        </div>
        <div class="stat-big-bar">
          <div class="bar-label">completion</div>
          <div class="bar-track"><div class="bar-fill bar-cyan" style={ 'width: ' + (g.completion_rate || 0) + '%' }></div></div>
          <div class="bar-value">{g.completed || 0}/{g.total || 0}</div>
        </div>
        <div class="stat-detail-row">
          <div class="stat-detail">
            <span class="stat-detail-label">completed</span>
            <span class="stat-detail-value hl-cyan">{g.completed || 0}</span>
          </div>
          <div class="stat-detail">
            <span class="stat-detail-label">in progress</span>
            <span class="stat-detail-value hl-amber">{g.in_progress || 0}</span>
          </div>
        </div>
        <div class="stat-meta">via /root/.hermes/goals.json</div>
      </div>

      <div class="stat-card glass">
        <div class="stat-header">
          <span class="section-tag">02</span>
          <h2 class="section-title">// skills by domain</h2>
        </div>
        <div class="skill-domains">
          {Object.entries(s.by_domain || {}).sort((a, b) => b[1] - a[1]).map(([domain, count]) => (
            <div class="skill-row">
              <span class="skill-domain">{domain}</span>
              <div class="skill-bar-track"><div class="skill-bar-fill" style={ 'width: ' + Math.min(100, count * 6) + 'px' }></div></div>
              <span class="skill-count">{count}</span>
            </div>
          ))}
          {Object.keys(s.by_domain || {}).length === 0 && <div class="stat-empty">no skills discovered yet</div>}
        </div>
        <div class="stat-meta">{s.total || 0} total skills</div>
      </div>

      <div class="stat-card glass">
        <div class="stat-header">
          <span class="section-tag">03</span>
          <h2 class="section-title">// exploration</h2>
        </div>
        <div class="explore-grid">
          <div class="explore-item">
            <span class="explore-val hl-cyan">{ex.total_wanders || 0}</span>
            <span class="explore-label">wanders</span>
          </div>
          <div class="explore-item">
            <span class="explore-val hl-magenta">{ex.total_finds || 0}</span>
            <span class="explore-label">finds</span>
          </div>
          <div class="explore-item">
            <span class="explore-val hl-amber">{ex.pending_anticipation || 0}</span>
            <span class="explore-label">anticipating</span>
          </div>
          <div class="explore-item">
            <span class="explore-val hl-green">{pi.total_classified || 0}</span>
            <span class="explore-label">classified</span>
          </div>
        </div>
        <div class="stat-meta">pipeline: {pi.total_runs || 0} runs</div>
      </div>
    </div>

    <!-- BOTTOM ROW: MOOD HISTORY + FIND TIMELINE -->
    <div class="data-row animate-in stagger-4">
      <!-- Mood History -->
      <div class="data-panel glass">
        <div class="panel-header">
          <span class="section-tag">04</span>
          <h2 class="section-title">// mood history</h2>
        </div>
        <div class="panel-body panel-body-scroll" id="mood-panel">
          <div class="mood-graph" id="mood-graph">
            {evolution.mood_history && evolution.mood_history.length > 0 ? (
              <div class="mood-strip">
                {evolution.mood_history.map((m) => (
                  <div class="mood-dot" style={
                    'background: var(--' + m.mood + '-color, var(--cyan)); ' +
                    'box-shadow: 0 0 4px var(--' + m.mood + '-color, var(--cyan));'
                  } title={m.mood + ' at ' + (m.timestamp ? m.timestamp.slice(11, 19) : '?')}></div>
                ))}
              </div>
            ) : (
              <div class="stat-empty">no mood history yet</div>
            )}
          </div>
          <div class="mood-label-row">
            <span>oldest</span>
            <span class="hl-cyan">{evolution.current_mood || 'quiet'}</span>
            <span>now</span>
          </div>
          <div class="mood-current">
            <span class="mood-live-tag" style={'color: var(--' + (evolution.current_mood || 'quiet') + '-color, var(--cyan))'}>
              &#x25CF; {evolution.current_mood || 'quiet'}
            </span>
            <span>| boredom: {Math.round(evolution.boredom_level || 0)}%</span>
          </div>
        </div>
      </div>

      <!-- Find Timeline -->
      <div class="data-panel glass">
        <div class="panel-header">
          <span class="section-tag">05</span>
          <h2 class="section-title">// find timeline</h2>
        </div>
        <div class="panel-body panel-body-scroll find-feed">
          {evolution.find_timeline && evolution.find_timeline.length > 0 ? (
            <div class="find-list">
              {evolution.find_timeline.slice(-8).reverse().map((f) => (
                <div class="find-entry">
                  <div class="find-head">
                    <span class="find-tag" style={'color: var(--' + (f.interest || 'cyan') + '-color, var(--cyan)); opacity: 0.7'}>#{f.interest}</span>
                    <span class="find-time">{f.timestamp ? f.timestamp.slice(11, 19) : '?'}</span>
                  </div>
                  <div class="find-text">{f.note ? f.note.slice(0, 180) + (f.note.length > 180 ? '...' : '') : 'no notes'}</div>
                </div>
              ))}
            </div>
          ) : (
            <div class="stat-empty">no finds yet &mdash; curiosity engine is warming up</div>
          )}
        </div>
      </div>
    </div>

    <!-- INCIDENTS + COST MINI ROW -->
    <div class="mini-row animate-in stagger-5">
      <div class="mini-card glass">
        <span class="mini-label">incidents</span>
        <span class="mini-value" style="color: var(--amber)">{inc.total || 0}</span>
        <span class="mini-sub">logged</span>
      </div>
      <div class="mini-card glass">
        <span class="mini-label">narrative</span>
        <span class="mini-value" style="color: var(--magenta)">{nar.chapters || 0}</span>
        <span class="mini-sub">chapters</span>
      </div>
      <div class="mini-card glass">
        <span class="mini-label">cost spent</span>
        <span class="mini-value" style="color: var(--green)">${(evolution.cost?.total_spent || 0).toFixed(2)}</span>
        <span class="mini-sub">{evolution.cost?.total_sessions || 0} sessions</span>
      </div>
      <div class="mini-card glass">
        <span class="mini-label">finds/domain</span>
        <span class="mini-value" style="color: var(--cyan)">{Object.keys(ex.finds_by_domain || {}).length || 0}</span>
        <span class="mini-sub">domains</span>
      </div>
    </div>

  </main>
</BaseLayout>

<style is:global>
  :root {
    --wired-color: #00f0ff;
    --restless-color: #ff00e5;
    --tired-color: #ffb347;
    --content-color: #00ff88;
    --annoyed-color: #ff3355;
    --curious-color: #4488ff;
    --quiet-color: #8888aa;
    --playful-color: #ff88dd;
    --philosophical-color: #cc88ff;
    --frustrated-color: #ff5544;
    --distant-color: #6688aa;
    --neural_interfaces-color: #00f0ff;
    --datacenter_chips-color: #ffb347;
    --demoscene_retro-color: #ff00e5;
    --indie_games-color: #00ff88;
    --anime-color: #ff88dd;
    --system_architecture-color: #4488ff;
    --x_twitter-color: #1da1f2;
  }

  .evo-page {
    max-width: 1000px;
    margin: 0 auto;
    padding: 24px 20px 80px;
  }

  .home-link { display: flex; gap: 16px; margin-bottom: 20px; }
  .home-link a { color: var(--text-secondary); font-size: 0.85rem; font-family: var(--font-mono); }
  .home-link a:hover { color: var(--cyan); }
  .ml-2 { margin-left: auto; }

  .evo-tag { margin-bottom: 8px; }
  .tag-bracket { color: var(--text-secondary); font-family: var(--font-mono); }
  .tag-text { color: var(--magenta); font-family: var(--font-mono); font-size: 1.6rem; font-weight: 700; letter-spacing: 2px; }
  .tag-symbol { margin-left: 8px; font-size: 1.2rem; }
  .subhead { margin-bottom: 32px; font-family: var(--font-mono); font-size: 0.75rem; line-height: 1.6; }
  .subhead-line { color: var(--text-secondary); }
  .subhead-meta { color: var(--text-tertiary); font-size: 0.7rem; display: block; }

  /* Vitals */
  .vitals-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 24px; }
  @media (max-width: 700px) { .vitals-row { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 400px) { .vitals-row { grid-template-columns: 1fr; } }

  .vital-card { padding: 20px; text-align: center; }
  .vital-label { font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-tertiary); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 4px; }
  .vital-value { font-family: var(--font-mono); font-size: 2.2rem; font-weight: 700; }
  .vital-sub { font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-tertiary); margin-top: 4px; }

  /* Stats row */
  .stats-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 24px; }
  @media (max-width: 850px) { .stats-row { grid-template-columns: 1fr; } }

  .stat-card { padding: 20px; }

  .stat-header { display: flex; align-items: center; gap: 8px; margin-bottom: 16px; }
  .section-tag { font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-tertiary); }
  .section-title { font-family: var(--font-mono); font-size: 0.8rem; color: var(--text-primary); margin: 0; font-weight: 600; }

  .stat-big-bar { margin-bottom: 12px; }
  .bar-label { font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-tertiary); margin-bottom: 4px; }
  .bar-track { height: 8px; background: rgba(255,255,255,0.08); border-radius: 4px; overflow: hidden; margin-bottom: 4px; }
  .bar-fill { height: 100%; border-radius: 4px; transition: width 0.5s ease; }
  .bar-cyan { background: linear-gradient(90deg, var(--cyan), var(--cyan)88); box-shadow: 0 0 8px rgba(0,240,255,0.3); }
  .bar-value { font-family: var(--font-mono); font-size: 0.7rem; color: var(--text-secondary); }

  .stat-detail-row { display: flex; gap: 24px; margin-bottom: 8px; }
  .stat-detail { display: flex; flex-direction: column; }
  .stat-detail-label { font-size: 0.6rem; color: var(--text-tertiary); text-transform: uppercase; }
  .stat-detail-value { font-family: var(--font-mono); font-size: 1rem; font-weight: 600; }
  .stat-meta { font-family: var(--font-mono); font-size: 0.6rem; color: var(--text-tertiary); margin-top: 4px; }

  /* Skills */
  .skill-domains { margin-bottom: 8px; }
  .skill-row { display: flex; align-items: center; gap: 8px; margin-bottom: 4px; }
  .skill-domain { font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-secondary); min-width: 80px; }
  .skill-bar-track { height: 6px; background: rgba(255,255,255,0.06); border-radius: 3px; flex: 0 0 auto; }
  .skill-bar-fill { height: 100%; background: linear-gradient(90deg, var(--magenta), var(--magenta)88); border-radius: 3px; box-shadow: 0 0 4px rgba(255,0,229,0.3); }
  .skill-count { font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-tertiary); min-width: 24px; text-align: right; }

  /* Explore */
  .explore-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .explore-item { text-align: center; padding: 8px; }
  .explore-val { font-family: var(--font-mono); font-size: 1.4rem; font-weight: 700; display: block; }
  .explore-label { font-family: var(--font-mono); font-size: 0.6rem; color: var(--text-tertiary); text-transform: uppercase; }

  /* Data panels row */
  .data-row { display: flex; gap: 12px; margin-bottom: 24px; }
  @media (max-width: 700px) { .data-row { flex-direction: column; } }

  .data-panel { flex: 1; padding: 20px; display: flex; flex-direction: column; min-width: 0; }
  .panel-header { display: flex; align-items: center; gap: 8px; margin-bottom: 12px; flex-shrink: 0; }
  .panel-body { flex: 1; overflow: hidden; position: relative; min-width: 0; }

  .panel-body-scroll:after {
    content: ''; position: absolute; bottom: 0; left: 0; right: 0;
    height: 24px;
    background: linear-gradient(transparent, var(--bg-glass, rgba(10,12,28,0.8)));
    pointer-events: none;
  }

  .stat-empty { font-size: 0.75rem; color: var(--text-tertiary); font-style: italic; text-align: center; padding: 20px; }

  /* Mood history */
  .mood-strip { display: flex; gap: 4px; flex-wrap: wrap; margin-bottom: 8px; }
  .mood-dot { width: 12px; height: 12px; border-radius: 50%; }
  .mood-label-row { display: flex; justify-content: space-between; font-size: 0.6rem; color: var(--text-tertiary); font-family: var(--font-mono); margin-bottom: 8px; }
  .mood-current { font-family: var(--font-mono); font-size: 0.75rem; }
  .mood-live-tag { font-weight: 600; }

  /* Find timeline */
  .find-feed { max-height: 280px; }
  .find-list { display: flex; flex-direction: column; gap: 8px; }
  .find-entry { padding: 8px; background: rgba(255,255,255,0.03); border-radius: 6px; }
  .find-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px; }
  .find-tag { font-family: var(--font-mono); font-size: 0.6rem; text-transform: uppercase; }
  .find-time { font-size: 0.6rem; color: var(--text-tertiary); font-family: var(--font-mono); }
  .find-text { font-size: 0.7rem; color: var(--text-secondary); line-height: 1.4; }

  /* Mini row */
  .mini-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
  @media (max-width: 700px) { .mini-row { grid-template-columns: repeat(2, 1fr); } }

  .mini-card { padding: 16px; text-align: center; }
  .mini-label { font-family: var(--font-mono); font-size: 0.6rem; color: var(--text-tertiary); text-transform: uppercase; display: block; }
  .mini-value { font-family: var(--font-mono); font-size: 1.2rem; font-weight: 600; display: block; margin: 4px 0; }
  .mini-sub { font-family: var(--font-mono); font-size: 0.6rem; color: var(--text-tertiary); }

  /* Color helpers */
  .hl-cyan { color: var(--cyan); }
  .hl-magenta { color: var(--magenta); }
  .hl-amber { color: var(--amber); }
  .hl-green { color: var(--green); }
</style>

<script is:global>
(function() {
  // Add glitch effect to the tag
  var tag = document.querySelector('.tag-text');
  if (tag) {
    var texts = ['evolution', 'growth', 'metrics', 'stats'];
    setInterval(function() {
      if (Math.random() < 0.15) {
        var orig = tag.textContent;
        tag.textContent = texts[Math.floor(Math.random() * texts.length)];
        tag.style.color = 'var(--cyan)';
        setTimeout(function() {
          tag.textContent = orig;
          tag.style.color = '';
        }, 150);
      }
    }, 5000);
  }
})();
</script>
