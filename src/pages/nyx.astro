      font-family: var(--font-mono);
      font-size: 0.85rem;
      line-height: 1.8;
    }
    .hb-line { margin-bottom: 0.3rem; }
    .prompt { color: var(--green); margin-right: 0.5rem; }
    .cmd { color: var(--text-primary); }
    .output {
      color: var(--text-secondary);
      padding-left: 1.2rem;
    }
    .blink {
      animation: pulseCursor 1s ease-in-out infinite;
      color: var(--green);
    }
    @keyframes pulseCursor {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.2; }
