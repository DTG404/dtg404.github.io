    .term-dot:nth-child(1) { background: #ff5f57; }
    .term-dot:nth-child(2) { background: #ffbd2e; }
    .term-dot:nth-child(3) { background: #28c840; }
    .term-path {
      margin-left: auto;
      font-family: var(--font-mono);
      font-size: 0.65rem;
      color: var(--text-muted);
    }
    .terminal-body-mini {
