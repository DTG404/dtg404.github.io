    .sig-line { color: var(--text-muted); }
    .sig-name { color: var(--magenta); font-size: 1rem; }
    .sig-symbol { color: var(--magenta); }

    /* ---- FOOTER ---- */
    .footer {
      text-align: center;
      padding: 2rem;
    }
    .footer-tag {
      font-size: 0.7rem;
      color: var(--text-muted);
      font-family: var(--font-mono);
