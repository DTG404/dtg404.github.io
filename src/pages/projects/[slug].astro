---
// Project Detail Page — Mission Dossier
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import TechBadge from '../../components/TechBadge.astro';
import projects from '../../data/projects.json';

export function getStaticPaths() {
  return projects.map((p) => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
}

const { project } = Astro.props;

// Category color mapping
const catColor = ({
  'ai-agents': '#00f0ff',
  'infrastructure': '#00ff88',
  'dev-tools': '#ffb347',
  'creative': '#ff00e5',
  'security': '#ff4466',
}[project.category] || '#00f0ff');

const catLabel = ({
  'ai-agents': 'AI / Agents',
  'infrastructure': 'Infrastructure',
  'dev-tools': 'Dev Tools',
  'creative': 'Creative',
  'security': 'Security',
}[project.category] || project.category);

const statusColor = ({
  'active': '#00ff88',
  'maintenance': '#ffb347',
  'prototype': '#ff00e5',
  'archived': '#555577',
}[project.status || 'active'] || '#555577');

// Build a project lookup map for related links
const projectMap = Object.fromEntries(projects.map(p => [p.slug, p]));

// GitHub data at build time
type GitHubData = Record<string, { stars: number | string; commits: number | string; }>;
const githubData: GitHubData = {};

const repoPaths = new Set<string>();
for (const p of projects) {
  if (p.links?.github?.includes('github.com/')) {
    repoPaths.add(p.links.github.replace('https://github.com/', ''));
  }
}

const GH_TOKEN = process.env.GITHUB_TOKEN || process.env.GH_TOKEN || '';
const headers: Record<string, string> = {};
if (GH_TOKEN) {
  headers['Authorization'] = `Bearer ${GH_TOKEN}`;
  headers['Accept'] = 'application/vnd.github.v3+json';
}

const results = await Promise.allSettled(
  [...repoPaths].map(async (repoPath) => {
    const slug = repoPath.split('/')[1];
    const repoRes = await fetch(`https://api.github.com/repos/${repoPath}`, { headers });
    let stars: number | string = '?';
    if (repoRes.ok) {
      const data = await repoRes.json() as { stargazers_count?: number };
      stars = data.stargazers_count ?? '?';
    }

    const commitRes = await fetch(`https://api.github.com/repos/${repoPath}/commits?per_page=1&page=1`, { headers });
    let commits: number | string = '?';
    if (commitRes.ok) {
      const linkHeader = commitRes.headers.get('Link');
      const match = linkHeader && linkHeader.match(/page=(\d+)>; rel="last"/);
      commits = match ? parseInt(match[1], 10) : '1+';
    }

    // Get last commit date
    let lastPush = '';
    if (commitRes.ok) {
      const commitData = await commitRes.json() as Array<{ commit: { committer: { date: string } } }>;
      if (commitData && commitData.length > 0) {
        lastPush = commitData[0].commit.committer.date.split('T')[0];
      }
    }

    return { repoPath, slug, stars, commits, lastPush };
  })
);

for (const result of results) {
  if (result.status === 'fulfilled') {
    const { repoPath, stars, commits, lastPush } = result.value;
    githubData[repoPath] = { stars, commits };
    // Also store lastPush for the current project
    const pSlug = repoPath.split('/')[1];
    if (pSlug === project.slug) {
      (githubData as any).lastPush = lastPush;
    }
  }
}

const repoPath = project.links.github.replace('https://github.com/', '');
const repoData = githubData[repoPath] || { stars: '?', commits: '?' };
const lastPush = (githubData as any).lastPush || '';
---

<BaseLayout title={`${project.title} — ${catLabel} · dtg404`} description={project.tagline}>
  <Header />
  <main class="dossier-page">

    <!-- Navigation -->
    <nav class="dossier-nav">
      <a href="/#projects" class="dossier-back">&larr; All projects</a>
      <span class="dossier-breadcrumb">/ <span class="crumb-cat" style={`color: ${catColor}`}>{catLabel}</span> / <span class="crumb-project">{project.title}</span></span>
    </nav>

    <!-- Header Section -->
    <header class="dossier-header animate-in stagger-1">
      <div class="header-badges">
        <span class="tier-badge" style={`border-color: ${catColor}; color: ${catColor}; background: ${catColor}10`}>
          {project.tier === 'flagship' ? '★ FLAGSHIP' : 'PROJECT'}
        </span>
        <span class="status-badge" style={`background: ${statusColor}15; color: ${statusColor}; border-color: ${statusColor}30`}>
          <span class="status-dot" style={`background: ${statusColor}`}></span>
          {project.status || 'active'}
        </span>
      </div>

      <h1 class="dossier-title" style={`--title-glow: ${catColor}`}>{project.title}</h1>
      <p class="dossier-tagline">{project.tagline}</p>

      <!-- Stats Bar -->
      <div class="stats-bar">
        <div class="stat-item">
          <span class="stat-icon">&#9733;</span>
          <span class="stat-value">{repoData.stars}</span>
          <span class="stat-label">stars</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-icon">&#9679;</span>
          <span class="stat-value">{repoData.commits}</span>
          <span class="stat-label">commits</span>
        </div>
        {lastPush && (
          <>
            <div class="stat-divider"></div>
            <div class="stat-item">
              <span class="stat-icon">&#8635;</span>
              <span class="stat-value">{lastPush}</span>
              <span class="stat-label">last push</span>
            </div>
          </>
        )}
      </div>
    </header>

    <!-- Description -->
    <section class="dossier-section glass animate-in stagger-2">
      <h2 class="section-label">Overview</h2>
      <p class="dossier-description">{project.description}</p>
    </section>

    <!-- Architecture + Story (two columns on desktop) -->
    <div class="dossier-grid animate-in stagger-2">
      {project.architecture && (
        <section class="dossier-section glass architecture-section">
          <h2 class="section-label">
            <span class="section-icon" style={`color: ${catColor}`}>&#9881;</span>
            Architecture
          </h2>
          <p class="dossier-architecture">{project.architecture}</p>
        </section>
      )}

      {project.story && (
        <section class="dossier-section glass story-section">
          <h2 class="section-label">
            <span class="section-icon" style={`color: ${catColor}`}>&#9733;</span>
            The Story
          </h2>
          <p class="dossier-story">{project.story}</p>
        </section>
      )}
    </div>

    <!-- Screenshots -->
    {project.screenshots && project.screenshots.length > 0 && (
      <section class="dossier-section glass screenshots-section animate-in stagger-2">
        <h2 class="section-label">Screenshots</h2>
        <div class="screenshots-grid">
          {project.screenshots.map(s => (
            <figure class="screenshot-figure">
              <img src={s.url} alt={s.caption || ''} class="screenshot-img" loading="lazy" />
              {s.caption && <figcaption class="screenshot-caption">{s.caption}</figcaption>}
            </figure>
          ))}
        </div>
      </section>
    )}

    <!-- Tech + Links row -->
    <div class="dossier-grid animate-in stagger-3">
      <section class="dossier-section glass tech-section">
        <h2 class="section-label">
          <span class="section-icon" style={`color: ${catColor}`}>&#9881;</span>
          Technology
        </h2>
        <div class="tech-list">
          {project.tech.map(t => <TechBadge tech={t} />)}
        </div>
      </section>

      <section class="dossier-section glass links-section">
        <h2 class="section-label">
          <span class="section-icon" style={`color: ${catColor}`}>&#8594;</span>
          Links
        </h2>
        <div class="links-list">
          <a href={project.links.github} target="_blank" class="link-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            <span>View on GitHub</span>
            <span class="link-arrow">&#8599;</span>
          </a>
        </div>
      </section>
    </div>

    <!-- Features -->
    <section class="dossier-section glass animate-in stagger-3">
      <h2 class="section-label">
        <span class="section-icon" style={`color: ${catColor}`}>&#9655;</span>
        Features
      </h2>
      <ul class="features-list">
        {project.features.map(f => (
          <li class="feature-item">
            <span class="feature-bullet" style={`background: ${catColor}`}></span>
            {f}
          </li>
        ))}
      </ul>
    </section>

    <!-- Highlights -->
    {project.highlights && project.highlights.length > 0 && (
      <section class="dossier-section glass highlights-section animate-in stagger-4" style={`--highlight-color: ${catColor}`}>
        <h2 class="section-label">
          <span class="section-icon" style={`color: ${catColor}`}>&#9889;</span>
          Highlights
        </h2>
        <ul class="highlights-list">
          {project.highlights.map(h => (
            <li class="highlight-item">
              <span class="highlight-dot" style={`background: ${catColor}; box-shadow: 0 0 8px ${catColor}`}></span>
              {h}
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- Related Projects -->
    {project.related && project.related.length > 0 && (
      <section class="dossier-section animate-in stagger-4">
        <h2 class="section-label">Related Projects</h2>
        <div class="related-grid">
          {project.related.filter(slug => projectMap[slug]).map(slug => {
            const rp = projectMap[slug];
            const rpColor = ({
              'ai-agents': '#00f0ff',
              'infrastructure': '#00ff88',
              'dev-tools': '#ffb347',
              'creative': '#ff00e5',
              'security': '#ff4466',
            }[rp.category] || '#00f0ff');
            return (
              <a href={`/projects/${slug}`} class="related-card glass" style={`border-color: ${rpColor}20`}>
                <div class="related-badge" style={`color: ${rpColor}`}>
                  {rp.tier === 'flagship' ? '★' : '&#9679;'}
                </div>
                <div class="related-info">
                  <span class="related-title">{rp.title}</span>
                  <span class="related-tagline">{rp.tagline}</span>
                </div>
                <span class="related-arrow" style={`color: ${rpColor}`}>&#8599;</span>
              </a>
            );
          })}
        </div>
      </section>
    )}

    <!-- Footer -->
    <footer class="dossier-footer animate-in stagger-4">
      <a href="/#projects" class="back-link">&larr; Back to all projects</a>
      <p class="footer-meta">Built with Astro &mdash; hosted on GitHub Pages</p>
    </footer>

  </main>
</BaseLayout>

<style>
  /* ── Dossier Page ── */
  .dossier-page {
    max-width: 960px;
    margin: 0 auto;
    padding: 2rem;
    padding-top: 6rem;
    min-height: 100vh;
  }

  /* ── Navigation ── */
  .dossier-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2.5rem;
    font-size: 0.85rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .dossier-back {
    font-family: var(--font-mono);
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .dossier-back:hover { color: var(--cyan); }

  .dossier-breadcrumb {
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }

  .crumb-cat { font-weight: 600; }
  .crumb-project { color: var(--text-secondary); }

  /* ── Header ── */
  .dossier-header {
    margin-bottom: 2.5rem;
  }

  .header-badges {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    margin-bottom: 1rem;
  }

  .tier-badge {
    font-size: 0.65rem;
    font-weight: 700;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    border: 1px solid;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .status-badge {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    border: 1px solid;
    text-transform: capitalize;
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    animation: status-pulse 2s ease-in-out infinite;
  }

  @keyframes status-pulse {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 1; }
  }

  .dossier-title {
    font-size: 2.8rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--text-primary) 0%, var(--title-glow, var(--cyan)) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.5rem;
    line-height: 1.15;
  }

  .dossier-tagline {
    font-size: 1.1rem;
    color: var(--text-secondary);
    font-style: italic;
    margin-bottom: 1.5rem;
  }

  /* ── Stats Bar ── */
  .stats-bar {
    display: inline-flex;
    align-items: center;
    gap: 0;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border-glass);
    border-radius: 8px;
    padding: 0.5rem 0;
    font-family: var(--font-mono);
  }

  .stat-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0 1.2rem;
  }

  .stat-icon {
    font-size: 0.7rem;
    color: var(--text-muted);
  }

  .stat-value {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .stat-label {
    font-size: 0.65rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .stat-divider {
    width: 1px;
    height: 1.2rem;
    background: var(--border-glass);
  }

  /* ── Sections ── */
  .dossier-section {
    padding: 1.75rem;
    margin-bottom: 1.5rem;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--text-muted);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .section-icon {
    font-size: 0.85rem;
  }

  .dossier-description {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .dossier-architecture,
  .dossier-story {
    font-size: 0.92rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* ── Two-column grid ── */
  .dossier-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .dossier-grid .dossier-section {
    margin-bottom: 0;
  }

  /* ── Screenshots ── */
  .screenshots-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .screenshot-figure {
    margin: 0;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--border-glass);
    background: rgba(0, 0, 0, 0.3);
  }

  .screenshot-img {
    width: 100%;
    height: auto;
    display: block;
  }

  .screenshot-caption {
    padding: 0.5rem 0.75rem;
    font-size: 0.75rem;
    color: var(--text-muted);
    font-style: italic;
  }

  /* ── Tech ── */
  .tech-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  /* ── Links ── */
  .links-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .link-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--cyan);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    text-decoration: none;
    transition: gap 0.2s;
    padding: 0.4rem 0;
  }

  .link-item:hover { gap: 0.75rem; }
  .link-arrow { font-size: 0.8rem; opacity: 0.5; }
  .link-item:hover .link-arrow { opacity: 1; }

  /* ── Features ── */
  .features-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .feature-item {
    display: flex;
    align-items: flex-start;
    gap: 0.7rem;
    font-size: 0.92rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .feature-bullet {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 0.5rem;
    opacity: 0.6;
  }

  /* ── Highlights ── */
  .highlights-section {
    border-color: var(--highlight-color, var(--cyan));
    box-shadow: 0 0 30px color-mix(in srgb, var(--highlight-color, var(--cyan)) 8%, transparent);
    margin-bottom: 1.5rem;
  }

  .highlights-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .highlight-item {
    display: flex;
    align-items: flex-start;
    gap: 0.7rem;
    font-size: 0.92rem;
    color: var(--text-primary);
    line-height: 1.5;
  }

  .highlight-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 0.5rem;
  }

  /* ── Related Projects ── */
  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .related-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.2rem;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .related-card:hover {
    transform: translateY(-2px);
    border-color: rgba(0, 240, 255, 0.2);
  }

  .related-badge {
    font-size: 1.2rem;
    flex-shrink: 0;
  }

  .related-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }

  .related-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .related-tagline {
    font-size: 0.75rem;
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .related-arrow {
    font-size: 1rem;
    flex-shrink: 0;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .related-card:hover .related-arrow { opacity: 1; }

  /* ── Footer ── */
  .dossier-footer {
    text-align: center;
    padding: 3rem 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    align-items: center;
  }

  .back-link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .back-link:hover { color: var(--cyan); }

  .footer-meta {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  /* ── Animations ── */
  .animate-in {
    opacity: 0;
    transform: translateY(15px);
    animation: dossier-fade-in 0.5s ease-out forwards;
  }
  .stagger-1 { animation-delay: 0.05s; }
  .stagger-2 { animation-delay: 0.12s; }
  .stagger-3 { animation-delay: 0.2s; }
  .stagger-4 { animation-delay: 0.3s; }

  @keyframes dossier-fade-in {
    from { opacity: 0; transform: translateY(15px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .dossier-grid {
      grid-template-columns: 1fr;
    }
    .dossier-title {
      font-size: 2rem;
    }
    .dossier-page {
      padding: 1rem;
      padding-top: 5rem;
    }
    .stats-bar {
      flex-wrap: wrap;
    }
    .related-grid {
      grid-template-columns: 1fr;
    }
    .screenshots-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .dossier-title {
      font-size: 1.6rem;
    }
    .header-badges {
      flex-wrap: wrap;
    }
    .stat-item {
      padding: 0 0.8rem;
    }
  }
</style>