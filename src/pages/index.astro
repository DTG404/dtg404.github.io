---
// Index Page — Landing + Project Grid
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ProjectFilter from '../components/ProjectFilter.astro';
import TerminalPanel from '../components/TerminalPanel.astro';
import projects from '../data/projects.json';

const flagships = projects.filter(p => p.tier === 'flagship');
const supporting = projects.filter(p => p.tier === 'supporting');

// Build-time GitHub data fetch — replaces client-side XHR calls
// Avoids unauthenticated rate limiting (60 req/hr) by making one batch at build time
type GitHubData = Record<string, { stars: number | string; commits: number | string; }>;
const githubData: GitHubData = {};

// Collect unique repo paths
const repoPaths = new Set<string>();
for (const p of projects) {
  if (p.links?.github?.includes('github.com/')) {
    repoPaths.add(p.links.github.replace('https://github.com/', ''));
  }
}

// Fetch in parallel with optional auth token
const GH_TOKEN = process.env.GITHUB_TOKEN || process.env.GH_TOKEN || '';
const headers: Record<string, string> = {};
if (GH_TOKEN) {
  headers['Authorization'] = `Bearer ${GH_TOKEN}`;
  headers['Accept'] = 'application/vnd.github.v3+json';
}

const results = await Promise.allSettled(
  [...repoPaths].map(async (repoPath) => {
    const slug = repoPath.split('/')[1];

    // Fetch repo info
    const repoRes = await fetch(`https://api.github.com/repos/${repoPath}`, { headers });
    let stars: number | string = '?';
    if (repoRes.ok) {
      const data = await repoRes.json() as { stargazers_count?: number };
      stars = data.stargazers_count ?? '?';
    }

    // Fetch commit count (paginated — use Link header)
    const commitRes = await fetch(`https://api.github.com/repos/${repoPath}/commits?per_page=1&page=1`, { headers });
    let commits: number | string = '?';
    if (commitRes.ok) {
      const linkHeader = commitRes.headers.get('Link');
      const match = linkHeader && linkHeader.match(/page=(\d+)>; rel="last"/);
      commits = match ? parseInt(match[1], 10) : '1+';
    }

    return { repoPath, slug, stars, commits };
  })
);

for (const result of results) {
  if (result.status === 'fulfilled') {
    const { repoPath, stars, commits } = result.value;
    githubData[repoPath] = { stars, commits };
  }
}
---

<BaseLayout title="dtg404 | ~/" description="Building infrastructure for AI and automation. Portfolio of DTG404 — DevOps Lead, AI infrastructure builder, open source creator.">
  <Header />
  <TerminalPanel />
  <Hero />

  <main>
    <section id="projects" class="section">
      <div class="section-header animate-in stagger-3">
        <h2 class="section-title">
          <span class="title-accent">/</span> projects
        </h2>
        <p class="section-subtitle">Open source work across AI agents, infrastructure, developer tools, and creative coding</p>
      </div>

      <ProjectFilter />

      <h3 class="tier-heading featured animate-in stagger-3" data-tier="featured">
        <span class="heading-dot cyan-dot"></span>
        Featured
      </h3>
      <div class="project-grid">
        {flagships.map((p, i) => (
          <ProjectCard
            slug={p.slug}
            title={p.title}
            tagline={p.tagline}
            description={p.description}
            tier={p.tier}
            category={p.category}
            tech={p.tech}
            links={p.links}
          />
        ))}
      </div>

      <h3 class="tier-heading more animate-in stagger-3" data-tier="more">
        <span class="heading-dot magenta-dot"></span>
        More
      </h3>

      <div class="project-grid">
        {supporting.map((p, i) => (
          <ProjectCard
            slug={p.slug}
            title={p.title}
            tagline={p.tagline}
            description={p.description}
            tier={p.tier}
            category={p.category}
            tech={p.tech}
            links={p.links}
          />
        ))}
      </div>
    </section>

    <section class="section contact-section animate-in stagger-4">
      <div class="glass contact-card">
        <h2 class="contact-title">
          <span class="title-accent">$</span> contact
        </h2>
        <p class="contact-text">
          Find me building things on
          <a href="https://github.com/digitalghost404" target="_blank">GitHub</a>,
          connecting on
          <a href="https://www.linkedin.com/in/xcoleman" target="_blank">LinkedIn</a>,
          or reach out via
          <a href="mailto:xacoleman@proton.me">email</a>.
        </p>
        <div class="contact-links">
          <a href="https://github.com/digitalghost404" class="contact-link glass" target="_blank">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            GitHub
          </a>
          <a href="https://www.linkedin.com/in/xcoleman" class="contact-link glass" target="_blank">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
          <a href="mailto:xacoleman@proton.me" class="contact-link glass">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            Email
          </a>
        </div>
      </div>
    </section>
  </main>

  <div id="github-data" data-json={JSON.stringify(githubData)} style="display:none"></div>
  <script is:inline>
  (function() {
    // ---- SCROLL REVEAL ----
    var revealItems = document.querySelectorAll('.project-card, .tier-heading, .contact-section, .section-header');
    if ('IntersectionObserver' in window) {
      var revealObserver = new IntersectionObserver(function(entries) {
        for (var i = 0; i < entries.length; i++) {
          if (entries[i].isIntersecting) {
            entries[i].target.classList.add('revealed');
            revealObserver.unobserve(entries[i].target);
          }
        }
      }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
      for (var r = 0; r < revealItems.length; r++) {
        revealObserver.observe(revealItems[r]);
      }
    } else {
      // Fallback: just show everything
      for (var r2 = 0; r2 < revealItems.length; r2++) {
        revealItems[r2].classList.add('revealed');
      }
    }

    // ---- GITHUB STATS (build-time data) ----
    var GITHUB_DATA = JSON.parse(document.getElementById('github-data').getAttribute('data-json'));
    var cards = document.querySelectorAll('[data-repo]');
    for (var c = 0; c < cards.length; c++) {
      var repo = cards[c].getAttribute('data-repo');
      var slug = repo.split('/')[1];
      var starsEl = document.getElementById('stars-' + slug);
      var commitsEl = document.getElementById('commits-' + slug);
      var data = GITHUB_DATA[repo];
      if (data) {
        if (starsEl) starsEl.textContent = data.stars;
        if (commitsEl) commitsEl.textContent = data.commits;
      }
    }
  })();
  </script>

  <footer class="footer">
    <p>Built with Astro — hosted on GitHub Pages</p>
    <p class="footer-sub">&copy; 2026 dtg404</p>
    <p class="footer-nyx">// maintained by <span class="nyx-glitch">nyx</span> 🖤</p>
  </footer>

  <style>
    .section {
      max-width: 1200px;
      margin: 0 auto;
      padding: 4rem 2rem;
    }

    .section-header {
      margin-bottom: 3rem;
    }

    .section-title {
      font-family: var(--font-mono);
      font-size: 1.8rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }

    .title-accent {
      color: var(--cyan);
    }

    .section-subtitle {
      font-size: 1rem;
      color: var(--text-secondary);
    }

    .tier-heading {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      font-size: 1rem;
      font-weight: 600;
      color: var(--text-secondary);
      font-family: var(--font-mono);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 1.5rem;
      margin-top: 2.5rem;
    }

    .heading-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
    }

    .cyan-dot { background: var(--cyan); box-shadow: 0 0 8px var(--cyan); }
    .magenta-dot { background: var(--magenta); box-shadow: 0 0 8px var(--magenta); }

    .project-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
      gap: 1.5rem;
    }

    .contact-section {
      padding-bottom: 6rem;
    }

    .project-card,
    .tier-heading,
    .contact-section {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.5s ease-out, transform 0.5s ease-out;
    }

    .project-card.revealed,
    .tier-heading.revealed,
    .contact-section.revealed {
      opacity: 1;
      transform: translateY(0);
    }

    .contact-card {
      padding: 3rem;
      text-align: center;
      max-width: 600px;
      margin: 0 auto;
    }

    .contact-title {
      font-family: var(--font-mono);
      font-size: 1.4rem;
      margin-bottom: 1rem;
    }

    .contact-text {
      color: var(--text-secondary);
      font-size: 0.95rem;
      line-height: 1.8;
      margin-bottom: 2rem;
    }

    .contact-text a {
      color: var(--cyan);
      font-weight: 500;
    }

    .contact-links {
      display: flex;
      justify-content: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .contact-link {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.6rem 1.2rem;
      font-family: var(--font-mono);
      font-size: 0.85rem;
      color: var(--text-secondary);
      text-decoration: none;
      transition: all 0.2s;
    }

    .contact-link:hover {
      color: var(--cyan);
      border-color: rgba(0, 240, 255, 0.3);
    }

    .footer {
      text-align: center;
      padding: 2rem;
      font-size: 0.8rem;
      color: var(--text-muted);
      border-top: 1px solid var(--border-glass);
    }

    .footer-sub {
      margin-top: 0.3rem;
      font-family: var(--font-mono);
    }

    .footer-nyx {
      margin-top: 0.8rem;
      font-family: var(--font-mono);
      font-size: 0.75rem;
      color: var(--text-muted);
      opacity: 0.6;
      transition: opacity 0.3s;
    }

    .footer:hover .footer-nyx {
      opacity: 1;
    }

    .nyx-glitch {
      color: var(--magenta);
      transition: all 0.2s;
      cursor: default;
    }

    .nyx-glitch:hover {
      animation: glitch-skew 0.3s ease infinite;
      text-shadow: 2px 0 var(--cyan), -2px 0 var(--magenta);
    }

    @keyframes glitch-skew {
      0% { transform: skew(0deg); }
      20% { transform: skew(2deg); }
      40% { transform: skew(-1deg); }
      60% { transform: skew(3deg); }
      80% { transform: skew(-2deg); }
      100% { transform: skew(0deg); }
    }

    @media (max-width: 640px) {
      .project-grid {
        grid-template-columns: 1fr;
      }
      .section {
        padding: 2rem 1rem;
      }
    }
  </style>
</BaseLayout>